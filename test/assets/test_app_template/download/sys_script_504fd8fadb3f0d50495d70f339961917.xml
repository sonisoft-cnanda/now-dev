        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {
	
	var ticUtil = new x_taniu_tan_core.TaniumIntegrationCore();
	var computerSerialNumber = ticUtil.getEndpointSerialByID(
		current.getValue('endpoint_id')
	);
	
	if (computerSerialNumber) {
		current.setValue('endpoint_serial', computerSerialNumber);
	}
	
	current.update();
	
})(current, previous);]]></script>
