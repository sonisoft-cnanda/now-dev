        <client_script><![CDATA[function confirmURL(event){
	var newWindow;
	if (event){
		event.preventDefault();
	}
	
	var confirmMessage = 'Are you sure you want to be redirected to the Tanium Support portal?';
	
	var userConfirmed = confirm(confirmMessage);
	if (userConfirmed){
		newwindow = window.open("https://support.tanium.com/s/support-home");
		newWindow.opener = null;
	}
}]]></client_script>
